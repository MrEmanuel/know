{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/rule-set.schema.json",
  "title": "Knowledge Rule Set",
  "type": "object",
  "required": ["rules"],
  "additionalProperties": false,
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "status", "applies_to"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "proposed"]
          },
          "applies_to": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source"],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string"
                },
                "lines": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
